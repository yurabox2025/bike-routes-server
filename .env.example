PORT=4000
JWT_SECRET=change-me
DATA_FILE_PATH=../data/data.json
DATA_STORAGE_PROVIDER=auto
UPLOADS_DIR=./uploads
MAX_GPX_SIZE_MB=20
MAX_SIMPLIFIED_POINTS=5000
YADISK_TOKEN=your_yandex_disk_oauth_token
YADISK_BASE_DIR=/bike-app
YADISK_DATA_PATH=/bike-app/data/data.json
# Optional aliases if you prefer Render-specific env var names:
# RENDER_YADISK_TOKEN=
# RENDER_YADISK_BASE_DIR=/bike-app
# RENDER_YADISK_DATA_PATH=/bike-app/data/data.json
LOCAL_FALLBACK_ENABLED=true
ADMIN_NAME=admin
ADMIN_PIN=1234
